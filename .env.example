# Copiar este archivo a .env y rellenar los valores reales

# Base de datos
GAS_DB_HOST=localhost
GAS_DB_PORT=5441
GAS_DB_USER=postgres
GAS_DB_PASSWORD=gas-db
GAS_DB_NAME=gas-db

# Google Maps JavaScript API key
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# Google Maps Map ID (obligatorio para Advanced Markers)
# Crear uno en: https://console.cloud.google.com/google/maps-apis/studio/maps
GOOGLE_MAPS_MAP_ID=YOUR_GOOGLE_MAPS_MAP_ID_HERE
