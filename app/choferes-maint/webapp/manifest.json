{
  "_version": "1.73.1",
  "sap.app": {
    "id": "choferesmaint",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:lrop",
      "version": "1.20.0",
      "toolsId": "choferesmaint-template"
    },
    "dataSources": {
      "mainService": {
        "uri": "/odata/v4/config/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.0"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.136.7",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.templates": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "choferesmaint.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "@i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      }
    },
    "resources": {
      "css": []
    },
    "routing": {
      "config": {},
      "routes": [
        {
          "pattern": ":?query:",
          "name": "ChoferesList",
          "target": "ChoferesList"
        },
        {
          "pattern": "Choferes({key}):?query:",
          "name": "ChoferesObjectPage",
          "target": "ChoferesObjectPage"
        },
        {
          "pattern": "Choferes({key})/viajes({key2}):?query:",
          "name": "ViajesObjectPage",
          "target": "ViajesObjectPage"
        }
      ],
      "targets": {
        "ChoferesList": {
          "type": "Component",
          "id": "ChoferesList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "contextPath": "/Choferes",
              "variantManagement": "Page",
              "navigation": {
                "Choferes": {
                  "detail": {
                    "route": "ChoferesObjectPage"
                  }
                }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "ResponsiveTable",
                    "selectionMode": "Multi"
                  }
                }
              }
            }
          }
        },
        "ChoferesObjectPage": {
          "type": "Component",
          "id": "ChoferesObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/Choferes",
              "navigation": {
                "viajes": {
                  "detail": {
                    "route": "ViajesObjectPage"
                  }
                }
              },
              "controlConfiguration": {
                "viajes/@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "creationMode": {
                      "isCreateEnabled": "false"
                    }
                  }
                }
              }
            }
          }
        },
        "ViajesObjectPage": {
          "type": "Component",
          "id": "ViajesObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/Choferes/viajes"
            }
          }
        }
      }
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  }
}
