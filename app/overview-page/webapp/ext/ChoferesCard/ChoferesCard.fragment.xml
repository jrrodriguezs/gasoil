<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:ovp="sap.ovp.ui"
xmlns:template="http://schemas.sap.com/sapui5/extension/sap.ui.core.template/1">
    <VBox>
        <Table
            items="{choferesModel>/choferes}"
        >
            <columns>
                <Column >
                    <Text text="Chofer"></Text>
                </Column>
                <Column >
                    <Text text="Rendimiento"></Text>
                </Column>
            </columns>
            <items>
                <ColumnListItem>
                    <cells>
                        <HBox alignItems="Center">
                            <Avatar src="{choferesModel>choferImage}"
                                    />
                            <Text text="{choferesModel>nombreCompleto}"
                                  class="sapUiTinyMarginBegin" />
                        </HBox>
                        <RatingIndicator maxValue="5" 
                                        editable="false" 
                                        displayOnly="true" 
                                        value="{choferesModel>rendimientoRating}"/>
                    </cells>
                </ColumnListItem>
            </items>
        </Table>
    </VBox>
</core:FragmentDefinition>
