{
  "_version": "1.73.1",
  "sap.app": {
    "id": "viajesmaint",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:lrop",
      "version": "1.20.0",
      "toolsId": "viajesmaint-template"
    },
    "dataSources": {
      "mainService": {
        "uri": "/odata/v4/config/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.0"
        }
      }
    },
    "crossNavigation": {
      "inbounds": {
        "Viajes-manage": {
          "semanticObject": "Viajes",
          "action": "manage",
          "title": "{{appTitle}}",
          "signature": {
            "parameters": {},
            "additionalParameters": "allowed"
          }
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.136.7",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.ushell": {},
        "sap.fe.templates": {},
        "sap.suite.ui.microchart": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "viajesmaint.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "@i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      }
    },
    "resources": {
      "css": [
        {
          "uri": "ext/css/mapaRuta.css"
        }
      ]
    },
    "rootView": {
      "viewName": "sap.fe.core.rootView.NavContainer",
      "type": "XML",
      "async": true,
      "id": "appRootView"
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router"
      },
      "routes": [
        {
          "pattern": ":?query:",
          "name": "ViajesList",
          "target": "ViajesList"
        },
        {
          "pattern": "Viajes({key}):?query:",
          "name": "ViajesObjectPage",
          "target": "ViajesObjectPage"
        }
      ],
      "targets": {
        "ViajesList": {
          "type": "Component",
          "id": "ViajesList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "contextPath": "/Viajes",
              "variantManagement": "Page",
              "navigation": {
                "Viajes": {
                  "detail": {
                    "route": "ViajesObjectPage"
                  }
                }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.SelectionFields": {
                  "filterFields": {
                    "fecha": {
                      "settings": {
                        "operatorConfiguration": [
                          {
                            "path": "key",
                            "equals": "DATERANGE",
                            "exclude": false
                          }
                        ]
                      }
                    }
                  }
                },
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "ResponsiveTable",
                    "selectionMode": "Multi"
                  }
                }
              }
            }
          }
        },
        "ViajesObjectPage": {
          "type": "Component",
          "id": "ViajesObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/Viajes",
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.HeaderInfo": {
                  "headerTitle": {
                    "type": "XMLFragment",
                    "name": "viajesmaint.ext.fragment.HeaderTitle"
                  }
                },
                "@com.sap.vocabularies.UI.v1.HeaderFacets": {
                  "facets": {
                    "ChoferHeader": {
                      "type": "XMLFragment",
                      "name": "viajesmaint.ext.fragment.ChoferHeader",
                      "title": "Chofer",
                      "stashed": false,
                      "position": {
                        "placement": "Before",
                        "anchor": "VehiculoPlacaFacet"
                      }
                    },
                    "ConsumoPromedioMicroChart": {
                      "type": "XMLFragment",
                      "name": "viajesmaint.ext.fragment.ConsumoPromedioMicroChart",
                      "title": "Consumo promedio vs último",
                      "stashed": false,
                      "position": {
                        "placement": "After",
                        "anchor": "ViajesEnRutaFacet"
                      }
                    },
                    "HeaderCharts": {
                      "type": "XMLFragment",
                      "name": "viajesmaint.ext.fragment.HeaderCharts",
                      "title": "Histórico de consumos",
                      "stashed": false,
                      "position": {
                        "placement": "After",
                        "anchor": "ConsumoPromedioMicroChart"
                      }
                    }
                  }
                }
              },
              "content": {
                "body": {
                  "sections": {
                    "MapaRuta": {
                      "template": "viajesmaint.ext.fragment.MapaRuta",
                      "position": {
                        "placement": "After",
                        "anchor": "InfoViajeFacet"
                      },
                      "title": "Mapa de ruta",
                      "type": "XMLFragment"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "extends": {
      "extensions": {
        "sap.ui.controllerExtensions": {
          "sap.fe.templates.ObjectPage.ObjectPageController#viajesmaint::ViajesObjectPage": {
            "controllerName": "viajesmaint.ext.controller.ViajeObjectPage"
          }
        }
      }
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  }
}
