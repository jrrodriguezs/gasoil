{
  "name": "GasoilProyecto",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "dependencies": {
    "@cap-js-community/odata-v2-adapter": "^1.15.10",
    "@cap-js/postgres": "^2.1.3",
    "@sap/cds": "^9.7.0",
    "@sapui5/ts-types": "^1.92.2",
    "dotenv": "^17.4.2",
    "express": "^4"
  },
  "devDependencies": {
    "@cap-js/cds-test": "^0.4.1",
    "@cap-js/sqlite": "^2",
    "@eslint/js": "^9",
    "cds-plugin-ui5": "^0.13.0",
    "eslint": "^9"
  },
  "overrides": {
    "@ui5/builder": "^5.0.0-alpha.6",
    "@ui5/fs": "^5.0.0-alpha.6",
    "@ui5/logger": "^5.0.0-alpha.6",
    "@ui5/project": "^5.0.0-alpha.6",
    "@ui5/server": "^5.0.0-alpha.6",
    "flatted": "^3.4.2",
    "lodash": "^4.18.1",
    "tmp": "^0.2.7"
  },
  "cds": {
    "features": {
      "deploy_data_onconflict": "replace"
    },
    "requires": {
      "[test]": {
        "db": {
          "kind": "postgres",
          "impl": "@cap-js/postgres"
        }
      },
      "[prod]": {
        "db": {
          "kind": "postgres",
          "impl": "@cap-js/postgres"
        }
      }
    }
  },
  "scripts": {
    "start": "cds watch",
    "watch": "cds watch",
    "serve-production": "cds s --profile prod",
    "serve": "cds serve --with-mocks --in-memory?",
    "watch-vehiculos-maint": "cds watch --open vehiculosmaint/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-cajamaint": "cds watch --open cajamaint/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-caja-maint": "cds watch --open cajamaint/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-transmision-maint": "cds watch --open transmisionmaint/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-ruta-maint": "cds watch --open rutamaint/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-almacen-maint": "cds watch --open com.tandem.almacenmaint/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-overview-page": "cds watch --open overviewpage/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-rubros-maint": "cds watch --open rubrosmaint/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-ordenes-carga-maint": "cds watch --open ordenescargamaint/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "private": true,
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/vehiculos-maint",
    "app/motores-maint",
    "app/transmision-maint",
    "app/caja-maint",
    "app/transmision-maint",
    "app/ruta-maint",
    "app/proveedor-maint",
    "app/tanques-maint",
    "app/almacen-maint",
    "app/overview-page",
    "app/rubros-maint",
    "app/ordenes-carga-maint"
  ],
  "allowScripts": {
    "better-sqlite3@12.11.1": true,
    "@parcel/watcher@2.5.6": true
  }
}
